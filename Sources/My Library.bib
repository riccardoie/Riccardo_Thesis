	file = {Full Text PDF:/home/riccardo/snap/zotero-snap/common/Zotero/storage/ZX5PVB5R/Gao and Zhang - 2016 - A Survey of Homogeneous and Heterogeneous System Architectures in High Performance Computing.pdf:application/pdf},
}

@article{hendrickson_graph_2000-1,
	title = {Graph partitioning models for parallel computing},
	volume = {26},
	issn = {0167-8191},
